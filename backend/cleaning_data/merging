import pandas as pd
# 1. Load the two datasets
# Replace these with your actual filenames if different
file_path = r'C:\Users\mailm\Downloads\Disorders_by_country\backend\Mental health Depression disorder Data.csv'
df_mental = pd.read_csv(file_path, low_memory=False)
file_path_hdi = r'C:\Users\mailm\Downloads\Disorders_by_country\backend\HDI_Simplified.csv'
df_hdi = pd.read_csv(file_path_hdi, low_memory=False)

# 2. CRITICAL STEP: Ensure the 'Year' column is the same data type (Integer)
# This prevents 'ValueError: You are trying to merge on object and int64 columns'
df_mental['Year'] = pd.to_numeric(df_mental['Year'], errors='coerce')
df_hdi['Year'] = pd.to_numeric(df_hdi['Year'], errors='coerce')

# Drop any rows where 'Year' couldn't be converted (cleaning up the data)
df_mental = df_mental.dropna(subset=['Year'])
df_hdi = df_hdi.dropna(subset=['Year'])

# 3. Perform the Merge
# 'left_on' uses the country name from the mental health file
# 'right_on' uses the country name from the HDI file
# We use an 'inner' join to keep only rows where we have both health AND HDI data
merged_df = pd.merge(
    df_mental, 
    df_hdi, 
    left_on=['Entity', 'Year'], 
    right_on=['country', 'Year'],
    how='inner'
)

# 4. Cleanup: Remove the redundant 'country' column after the merge
merged_df = merged_df.drop(columns=['country'])

# 5. Save the final merged dataset
merged_df.to_csv('Merged_MentalHealth_HDI.csv', index=False)

print("Merge complete! The final dataset has been saved.")
print(merged_df[['Entity', 'Year', 'Depression (%)', 'hdi']].head())

file_path_unemp = r'C:\Users\mailm\Downloads\Disorders_by_country\backend\Cleaned_Employment_Unemployment_GDP.csv'
df_econ = pd.read_csv(file_path_unemp, low_memory = False)

# 2. Load the previously merged Mental Health + HDI data
file_path_master = r'C:\Users\mailm\Downloads\Disorders_by_country\backend\Merged_MentalHealth_HDI.csv'
df_prev = pd.read_csv(file_path_master, low_memory = False)

# 3. Ensure Year and Country columns match perfectly
# Mental Health file uses 'Entity', Economic file uses 'Country Name'
df_econ['Year'] = pd.to_numeric(df_econ['Year'], errors='coerce')
df_prev['Year'] = pd.to_numeric(df_prev['Year'], errors='coerce')

# 4. Perform the final merge
# We use 'inner' to keep only rows where all data points (Health, HDI, Econ) exist
master_df = pd.merge(
    df_prev, 
    df_econ, 
    left_on=['Entity', 'Year'], 
    right_on=['Country Name', 'Year'],
    how='inner'
)

# 5. Clean up redundant columns
master_df = master_df.drop(columns=['Country Name'])

# 6. Save the final Master Dataset
master_df.to_csv('Master_Bioinformatics_Dataset.csv', index=False)

print(f"Merge Complete! Final Row Count: {len(master_df)}")